{
	"name": "proply",
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"husky": "^9.1.7",
		"turbo": "^2"
	},
	"packageManager": "bun@1.2.21",
	"private": true,
	"scripts": {
		"dev": "turbo dev",
		"dev:widget": "turbo dev --filter=widget",
		"dev:wrangler": "turbo dev:wrangler",
		"build": "turbo build",
		"build:widget": "turbo build --filter=widget",
		"test:widget": "turbo test:page --filter=widget",
		"lint": "turbo lint",
		"format": "biome check .",
		"format:fix": "biome check . --write",
		"prepare": "husky"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"trustedDependencies": [
		"esbuild"
	]
}
